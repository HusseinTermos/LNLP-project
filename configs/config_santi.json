{
  "data": {
    "local_dir": "data/pubhealth_bigbio_pairs",
    "claim_column": "claim",
    "label_column": "label",
    "processed_dataset_path": "data/processed/pubhealth_rag_dataset_no_reform_f_reformatted.jsonl",
    "max_examples_per_split": 10000
  },
  "santi": {
    "num_pubmed_abstracts": 30000,
    "num_wikipedia_articles": 20000
  },
  "reformulation": {
    "enabled": false,
    "model_name": "Qwen/Qwen2.5-1.5B-Instruct",
    "model_load_mode": "local",
    "batch_size": 16,
    "temperature": 0.3,
    "max_new_tokens": 64,
    "cache_path": "data/cache/reformulation_cache_santi.json"
  },
  "rag": {
    "query_source": "original",
    "top_k": 3,
    "method": "cross_encoder",
    "chunk_size": 80,
    "chunk_overlap": 20,
    "embedding_model_name": "BAAI/bge-small-en-v1.5",
    "cross_encoder_model_name": "cross-encoder/ms-marco-MiniLM-L-6-v2",
    "reset_collection": true
  },
  "model": {
    "model_name": "allenai/scibert_scivocab_uncased",
    "max_length": 512,
    "label_map": {
      "false": 0,
      "mixture": 1,
      "true": 2,
      "unproven": 3
    }
  },
  "training": {
    "processed_dataset_path": "data/processed/pubhealth_rag_dataset_no_reform_f_reformatted.jsonl",
    "output_dir": "models/scibert_santi",
    "epochs": 5,
    "learning_rate": 1e-5,
    "weight_decay": 0.1,
    "warmup_ratio": 0.1,
    "label_smoothing_factor": 0.05,
    "logging_steps": 20,
    "save_steps": 500,
    "batch_size": 8,
    "gradient_accumulation_steps": 2,
    "oversample_minority_classes": false,
    "use_class_weights": true,
    "early_stopping_patience": 2
  },
  "inference": {
    "model_dir": null,
    "batch_size": 16,
    "max_examples": 10000
  }
}
